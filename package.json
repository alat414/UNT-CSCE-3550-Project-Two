{
  "name": "projectone",
  "version": "1.0.0",
  "description": "JWKS server with key rotation and JWT authentication",
  "keywords": [
    "jwks",
    "jwt",
    "authentication",
    "key-rotation"
  ],
  "homepage": "https://github.com/alat414/UNT-CSCE-3550-Project-Two#readme",
  "bugs": {
    "url": "https://github.com/alat414/UNT-CSCE-3550-Project-Two/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alat414/UNT-CSCE-3550-Project-Two.git"
  },
  "license": "UNLICENSED",
  "author": "Gustavo Alatriste",
  "type": "commonjs",
  "main": "keyExpiry.js",
  "scripts": {
    "start": "node keyExpiry.js",
    "dev": "nodemon keyExpiry.js",
    "dev:app": "nodemon app.js",
    "test": "jest",
    "test:unit": "jest testing/unit_tests",
    "test:integration": "jest testing/integration_tests",
    "test:auth": "jest testing/integration_tests/authentication-flow.tests.js",
    "test:keys": "jest testing/integration_tests/key-rotation.tests.js",
    "test:expiry": "jest testing/integration_tests/token-expiry.tests.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "jest": {
    "testTimeout": 30000,
    "testEnvironment": "node",
    "testMatch": ["**/testing/**/*.tests.js"],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "collectCoverageFrom": [
      "keyExpiry.js",
      "keyStorage.js",
      "app.js",
      "!**/node_modules/**",
      "!**/testing/**"
    ],
    "coverageReporters": ["text", "html", "lcov"]
  },
  "dependencies": {
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}